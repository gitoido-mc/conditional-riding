{
  "schemaVersion": 1,
  "id": "conditional_riding",
  "version": "${version}",
  "name": "Cobblemon Conditional Riding",
  "description": "Allows to configure ability to ride pokemans via simple config!",
  "authors": [
    "Gito"
  ],
  "contact": {
    "issues": "https://github.com/gitoido-mc/conditional-riding/issues",
    "sources": "https://github.com/gitoido-mc/conditional-riding"
  },
  "license": "GPL-3.0-only",
  "icon": "assets/conditional_riding/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "value": "lol.gito.conditionalRiding.fabric.ConditionalRidingFabric",
        "adapter": "kotlin"
      }
    ]
  },
  "depends": {
    "minecraft": "1.21.1",
    "cobblemon": ">=1.7.3 <1.8.0",
    "fabric-permissions-api-v0": "*"
  }
}
